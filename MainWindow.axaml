<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ACG.MainWindow"
        Title="ACG">

  <DockPanel>
    <Border DockPanel.Dock="Top"
            Background="#0c0c12"
            BorderBrush="#2A2A50"
            BorderThickness="0,0,0,1"
            Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="8">

        <Button x:Name="LoadButton"
                Content="Открыть .obj"
                Padding="12,6"
                Foreground="#8888BB"
                ToolTip.Tip="Загрузить модель из .obj файла"/>

        <Button x:Name="ResetButton"
                Content="Сброс вида"
                Padding="12,6"
                Foreground="#8888BB"
                ToolTip.Tip="Вернуть камеру в начальное положение"/>

        <Rectangle Width="1" Height="22" Fill="#2A2A50" Margin="4,0"/>

        <TextBlock x:Name="StatusText"
                   VerticalAlignment="Center"
                   Foreground="#8888BB"
                   FontSize="12"/>
      </StackPanel>
    </Border>
<Grid>
  <Border x:Name="CanvasBorder"
          Background="#080818"
          ClipToBounds="True">
    <Image x:Name="RenderCanvas"
           Stretch="Uniform"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           RenderOptions.BitmapInterpolationMode="None"/>
  </Border>

  <TextBlock x:Name="FpsText"
             HorizontalAlignment="Right"
             VerticalAlignment="Top"
             Margin="0,8,12,0"
             Foreground="#8888BB"
             FontSize="12"
             FontFamily="Consolas"
             IsHitTestVisible="False"
             Text="0 fps"/>
</Grid>

  </DockPanel>
</Window>
