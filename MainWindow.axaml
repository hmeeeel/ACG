<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ACG.MainWindow"
        Title="ACG">

  <DockPanel>
    <Border DockPanel.Dock="Top"
            Background="#0c0c12"
            BorderBrush="#2A2A50"
            BorderThickness="0,0,0,1"
            Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="8">

        <Button x:Name="LoadButton"
                Content="Открыть .obj"
                Padding="12,6" Foreground="#8888BB"/>

        <Button x:Name="LoadDiffuseButton"
                Content="Diffuse"
                Padding="12,6" Foreground="#8888BB"
                ToolTip.Tip="PNG/BMP/JPG"/>

        <Button x:Name="LoadNormalButton"
                Content="Normal"
                Padding="12,6" Foreground="#8888BB"
                ToolTip.Tip="PNG/BMP/JPG"/>

        <Button x:Name="LoadSpecularButton"
                Content="Specular"
                Padding="12,6" Foreground="#8888BB"
                ToolTip.Tip="PNG/BMP/JPG"/>

        <Rectangle Width="1" Height="22" Fill="#2A2A50" Margin="4,0"/>

        <Button x:Name="ResetButton"
                Content="Сброс"
                Padding="12,6" Foreground="#8888BB"/>

        <ToggleButton x:Name="FilledButton"
                      Content="Каркас"
                      Padding="12,6" Foreground="#8888BB"/>

        <Rectangle Width="1" Height="22" Fill="#2A2A50" Margin="4,0"/>

        <TextBlock Text="Шейдинг:"
                   VerticalAlignment="Center"
                   Foreground="#666699" FontSize="12"/>
        <TextBlock x:Name="ModeText"
                   VerticalAlignment="Center"
                   Foreground="#BBBBEE" FontSize="12" FontWeight="Bold"
                   MinWidth="140"
                   ToolTip.Tip="L=Lambert  G=Гуро  B=Блинн-Фонг  P=Фонг  A=Ambient  D=Diffuse  S=Specular"/>

        <Rectangle Width="1" Height="22" Fill="#2A2A50" Margin="4,0"/>

        <TextBlock Text="Текстуры:"
                   VerticalAlignment="Center"
                   Foreground="#666699" FontSize="12"/>
        <TextBlock x:Name="TexModeText"
                   VerticalAlignment="Center"
                   Foreground="#BBBBEE" FontSize="12" FontWeight="Bold"
                   MinWidth="160"
                   ToolTip.Tip="T=Diffuse  N=Normal  M=Specular  O=Все  0=Без текстур"/>

        <Rectangle Width="1" Height="22" Fill="#2A2A50" Margin="4,0"/>

        <TextBlock x:Name="StatusText"
                   VerticalAlignment="Center"
                   Foreground="#8888BB" FontSize="12"/>
      </StackPanel>
    </Border>

    <Grid>
      <Border x:Name="CanvasBorder"
              Background="#080818"
              ClipToBounds="True">
        <Image x:Name="RenderCanvas"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapInterpolationMode="None"/>
      </Border>

      <TextBlock x:Name="FpsText"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,8,12,0"
                 Foreground="#8888BB" FontSize="12"
                 FontFamily="Consolas"
                 IsHitTestVisible="False" Text="0 fps"/>
    </Grid>
  </DockPanel>
</Window>